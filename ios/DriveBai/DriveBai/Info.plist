<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.drivebai.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>drivebai</string>
			</array>
		</dict>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- App Store / TestFlight friendly: ATS enforced by default.
		     Only localhost (DEBUG builds talking to a local backend) is
		     exempt; the production Fly endpoint already uses TLS so no
		     additional exception is required. -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<!-- Branded background instead of blank white on cold start.
		     AccentColor already exists in Assets.xcassets (brand teal). -->
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
</dict>
</plist>
