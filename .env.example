# =============================================================================
# DriveBai Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env at the project root (next to docker-compose.yml):
#
#   cp .env.example .env
#
# Then edit the values as needed and restart the containers:
#
#   make restart
#
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENV=development

# -----------------------------------------------------------------------------
# Security (CHANGE IN PRODUCTION!)
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=dev-secret-change-in-production

# -----------------------------------------------------------------------------
# Email Configuration (SendGrid)
# -----------------------------------------------------------------------------
# DEVELOPMENT: Leave SENDGRID_API_KEY empty - emails print to console (make logs)
# PRODUCTION:  Set your SendGrid API key to send real emails
#
# Setup steps:
# 1. Create account at https://sendgrid.com
# 2. Settings > API Keys > Create API Key (Mail Send permission)
# 3. Settings > Sender Authentication > Verify your sender email
# 4. Paste the key below (starts with "SG.")
#
# For detailed setup, see: docs/email.md
#
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=DriveBai

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Deep link scheme for mobile app (must match iOS Info.plist CFBundleURLSchemes)
APP_DEEPLINK_SCHEME=drivebai

# Base URL for the API (used in web fallback links in emails)
# Production example: https://api.drivebai.com
APP_BASE_URL=http://localhost:8080
